# Modello di secrets.yaml — copia questo file in `secrets.yaml` e compila i valori.
#   cp secrets.yaml.example secrets.yaml
# `secrets.yaml` è in .gitignore e NON va versionato.

# --- WiFi ---
wifi_ssid: "IL_TUO_SSID"
wifi_password: "LA_TUA_PASSWORD"

# --- Entity Home Assistant (adatta agli entity_id della tua istanza) ---
ent_um_giardino: sensor.umidita_giardino
ent_um_sala: sensor.umidita_sala
ent_um_camera: sensor.umidita_camera
ent_potenza: sensor.potenza_istantanea
ent_bolletta: sensor.previsione_bolletta_mensile
ent_temp_giardino: sensor.temperatura_giardino
ent_temp_sala: sensor.temperatura_sala
ent_temp_camera: sensor.temperatura_camera
ent_meteo: weather.casa
ent_persona1: person.persona_uno
ent_persona2: person.persona_due

# --- Nomi visualizzati sulla plancia ---
nome_persona1: "Persona 1"
nome_persona2: "Persona 2"
